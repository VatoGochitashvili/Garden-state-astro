---
import BaseLayout from "@/layouts/BaseLayout.astro";
import HeroBanner from "@/components/shared/HeroBanner.astro";
import EmergencyCTA from "@/components/shared/EmergencyCTA.astro";
import { ShieldCheck, Building2, Key, Lock, Settings, PhoneCall } from "lucide-react";
import commercialHero from "@/assets/commercial-locksmith-pushbar-nj.webp";

const commercialServices = [
  { icon: Building2, title: "Business Lockout Service", desc: "Can't get into your business? We dispatch commercial locksmiths fast to offices, warehouses, retail, and industrial properties across New Jersey.", link: "/services/emergency/business-lockout" },
  { icon: Lock, title: "High-Security Lock Systems", desc: "Medeco, Mul-T-Lock, and ABLOY high-security cylinders with patented key control — keys cannot be duplicated without your written authorization.", link: "/services/commercial/high-security-locks" },
  { icon: Settings, title: "Electronic Access Control", desc: "Key card, fob, and PIN systems with full audit trails. Add and remove users instantly without rekeying. Scalable from 1 door to 100+.", link: "/services/commercial/access-control-systems" },
  { icon: Key, title: "Master Key Systems", desc: "One key for managers, zone keys for employees. We design and implement master key hierarchies that give you granular control over your facility.", link: "/services/master-key-systems" },
  { icon: ShieldCheck, title: "Panic Hardware & Exit Devices", desc: "NJ-code-compliant panic bars and exit devices for commercial properties, schools, and healthcare facilities. Installation and annual inspection available.", link: "/services/commercial/panic-bar-installation" },
  { icon: PhoneCall, title: "Same-Day Emergency Service", desc: "Business lockouts, broken keys, or a busted commercial deadbolt — we dispatch fast for New Jersey businesses, 7 AM – 10 PM, six days a week.", link: "/emergency-locksmith" },
];

const industries = ["Office Buildings", "Retail Stores", "Warehouses & Logistics", "Healthcare & Medical Offices", "Schools & Universities", "Restaurants & Hospitality", "Government Facilities", "Multi-Tenant Buildings", "Industrial Facilities"];

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "Service",
  name: "Commercial Locksmith Services New Jersey",
  provider: { "@type": "LocalBusiness", name: "Garden State Locksmith", telephone: "+18565880580", areaServed: "New Jersey" },
  serviceType: "Commercial Locksmith",
  description: "Professional commercial locksmith services throughout New Jersey: business lockouts, access control, high-security locks, master key systems, and panic hardware.",
};
---

<BaseLayout
  title="Commercial Locksmith Services New Jersey | Garden State Locksmith"
  description="Professional commercial locksmith services throughout NJ: business lockouts, access control systems, high-security locks & master key systems. Call (856) 588-0580 7 AM – 10 PM."
  canonical="/commercial-locksmith"
  imageUrl={commercialHero.src}
  schema={jsonLd}
>
  <HeroBanner
    h1="Commercial Locksmith Services in New Jersey"
    subtitle="From business lockouts to enterprise access control systems — Garden State Locksmith protects New Jersey businesses with professional, licensed commercial locksmith services."
    emergency={true}
    image={commercialHero.src}
  />

  <section class="py-16 bg-background">
    <div class="container mx-auto px-4">
      <div class="text-center mb-12">
        <h2 class="text-3xl md:text-4xl font-serif font-bold mb-4">Commercial Security Services</h2>
        <p class="text-lg text-muted-foreground max-w-2xl mx-auto">Protecting New Jersey businesses of all sizes. We work with offices, warehouses, retail, healthcare, and more.</p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {commercialServices.map((s) => (
          <div class="rounded-xl border border-border/60 hover:shadow-md transition-shadow p-6">
            <div class="h-12 w-12 rounded-full bg-primary/10 flex items-center justify-center text-primary mb-4">
              <s.icon className="h-6 w-6" />
            </div>
            <h3 class="font-serif font-bold text-xl mb-2">{s.title}</h3>
            <p class="text-muted-foreground text-sm mb-4">{s.desc}</p>
            <a href={s.link} class="text-primary font-semibold text-sm hover:underline">Learn More &rarr;</a>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="py-16 bg-muted/30 border-y border-border/50">
    <div class="container mx-auto px-4">
      <h2 class="text-3xl font-serif font-bold mb-8 text-center">Industries We Serve</h2>
      <div class="flex flex-wrap justify-center gap-3 max-w-3xl mx-auto">
        {industries.map((ind) => (
          <span class="bg-primary text-primary-foreground px-4 py-2 rounded-full text-sm font-semibold">{ind}</span>
        ))}
      </div>
    </div>
  </section>

  <section class="py-16 bg-background">
    <div class="container mx-auto px-4 max-w-3xl text-center">
      <h2 class="text-3xl font-serif font-bold mb-4">Free Commercial Security Assessment</h2>
      <p class="text-lg text-muted-foreground mb-8">
        Not sure where your business's security gaps are? We'll visit your New Jersey property and provide a thorough security assessment at no charge. We identify vulnerabilities and recommend cost-effective solutions.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="tel:8565880580" class="inline-flex items-center justify-center rounded-md bg-primary text-primary-foreground font-bold min-h-10 px-8 text-lg">Call (856) 588-0580</a>
        <a href="/contact" class="inline-flex items-center justify-center rounded-md border border-primary text-primary font-bold min-h-10 px-8 text-lg">Request Assessment</a>
      </div>
    </div>
  </section>

  <EmergencyCTA
    title="Business Lockout? We Respond Fast."
    description="Every minute locked out of your business costs money. Garden State Locksmith dispatches commercial locksmiths throughout New Jersey 7 AM – 10 PM."
  />
</BaseLayout>
