---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { BookingForm } from "@/components/shared/BookingForm";
import LocationCard from "@/components/shared/LocationCard.astro";
import TestimonialSection from "@/components/shared/TestimonialSection.astro";
import EmergencyCTA from "@/components/shared/EmergencyCTA.astro";
import FAQAccordion from "@/components/shared/FAQAccordion.astro";
import { ServiceAreaMap } from "@/components/shared/ServiceAreaMap";
import { categories } from "@/data/categories";
import { locations } from "@/data/locations";
import { PRIORITY_SERVICE_LOCATION_LINKS } from "@/data/indexingPriority";
import { optimizeImageSrc } from "@/lib/image";
import { websiteSchema, organizationSchema, faqSchema } from "@/lib/seo";
import { Phone, CheckCircle2, ArrowRight, ShieldCheck, MapPin } from "lucide-react";
import heroPhoto from "@/assets/camden-hero-optimized.webp";

const topLocations = locations.slice(0, 12);

const BRANDS = ["Schlage", "Kwikset", "Yale", "Medeco", "Baldwin", "ASSA ABLOY", "Mul-T-Lock", "August", "Schlage", "Kwikset", "Yale", "Medeco", "Baldwin", "ASSA ABLOY"];

const STATS = [
  { value: "15+", label: "Years Experience" },
  { value: "5★", label: "Google Rated" },
  { value: "Same-Day", label: "Service" },
  { value: "NJ", label: "Licensed & Insured" },
  { value: "90+", label: "Cities Served" },
];

const faqs = [
  { question: "Are you licensed and insured in New Jersey?", answer: "Yes, Garden State Locksmith is fully licensed, bonded, and insured in the state of New Jersey. Our technicians undergo thorough background checks for your safety and peace of mind." },
  { question: "Do you offer 24-hour emergency services?", answer: "Absolutely. We understand that lockouts and security emergencies don't happen during standard business hours. Our mobile units are available 7 AM – 10 PM, 6 days a week throughout New Jersey and surrounding areas." },
  { question: "How long does it usually take for a locksmith to arrive?", answer: "For emergency calls throughout New Jersey, our typical response time is same day. We always aim to dispatch the nearest available technician to your location." },
  { question: "Can you make a new car key without the original?", answer: "Yes! We have advanced equipment to cut and program new keys, fobs, and transponders for almost all vehicle makes and models directly on-site, even if you've lost all original keys." },
  { question: "What areas of New Jersey do you serve?", answer: "We serve all of New Jersey including Camden, Burlington, Gloucester, Mercer, Ocean, Monmouth, Essex, Hudson, Bergen, and Passaic Counties. If you're in NJ, we can reach you." },
];

const homeSchema = [
  websiteSchema(),
  organizationSchema(),
  faqSchema(faqs.map((f) => ({ q: f.question, a: f.answer }))),
];
---

<BaseLayout
  title="Garden State Locksmith | Licensed NJ Locksmith Services"
  description="Fast, reliable, and professional locksmith services across New Jersey. Emergency lockouts, residential, commercial, and automotive locksmith. Call (856) 588-0580."
  canonical="/"
  schema={homeSchema}
>
  <!-- Split Hero -->
  <div class="relative overflow-hidden text-white" style="background: #0c1410;">
    <div class="absolute inset-0 pointer-events-none">
      <img src={heroPhoto.src} alt="" aria-hidden="true" fetchpriority="high" class="w-full h-full object-cover opacity-55" />
      <div class="absolute inset-0 bg-gradient-to-r from-black/85 via-black/60 to-black/70" />
      <div class="absolute inset-0 bg-gradient-to-t from-black/50 via-transparent to-black/20" />
    </div>
    <div class="absolute bottom-0 left-0 w-80 h-40 bg-primary/25 blur-3xl pointer-events-none" />

    <div class="relative container mx-auto px-4 py-20 lg:py-28">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <div>
          <div class="inline-flex items-center rounded-full border border-accent/50 bg-accent/15 px-3 py-1 text-sm font-semibold text-accent mb-6">
            <span class="flex h-2 w-2 rounded-full bg-accent mr-2 animate-pulse" />
            Fast Response · Licensed NJ Technicians
          </div>
          <p class="text-accent font-bold uppercase tracking-[0.2em] text-sm mb-3">Garden State Locksmith</p>
          <h1 class="text-4xl md:text-5xl lg:text-6xl font-serif font-bold tracking-tight mb-6 text-white drop-shadow-lg">
            New Jersey's Trusted Local Locksmith
          </h1>
          <p class="text-lg text-white/75 mb-8 leading-relaxed max-w-lg">
            Emergency lockouts, residential security, commercial access control, and automotive key solutions — licensed and trusted across all of New Jersey.
          </p>
          <div class="flex flex-wrap gap-3 mb-8">
            <a href="tel:8565880580" class="flex items-center gap-2 bg-primary text-primary-foreground font-bold px-7 py-3.5 rounded-full hover:bg-primary/90 transition-colors text-lg">
              <Phone className="h-5 w-5" /> (856) 588-0580
            </a>
          </div>
          <div class="flex flex-wrap gap-5 text-sm font-semibold text-white/60">
            <span class="flex items-center gap-1.5"><ShieldCheck className="h-4 w-4 text-accent" /> Licensed & Insured</span>
            <span class="flex items-center gap-1.5"><ShieldCheck className="h-4 w-4 text-accent" /> Background-Checked</span>
            <span class="flex items-center gap-1.5"><ShieldCheck className="h-4 w-4 text-accent" /> Satisfaction Guaranteed</span>
          </div>
        </div>

        <div class="lg:pl-6">
          <div class="rounded-2xl border border-white/15 p-7" style="background: rgba(0,0,0,0.55); backdrop-filter: blur(12px);">
            <p class="text-accent font-bold uppercase tracking-widest text-xs mb-1">Free Quote</p>
            <h2 class="text-2xl font-serif font-bold text-white mb-5">Schedule Service</h2>
            <BookingForm client:load darkBg compact />
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Stats Bar -->
  <div class="bg-primary text-primary-foreground">
    <div class="container mx-auto px-4">
      <div class="grid grid-cols-3 md:grid-cols-5 divide-x divide-primary-foreground/20">
        {STATS.map((stat) => (
          <div class="flex flex-col items-center justify-center py-5 px-2 text-center">
            <span class="text-2xl md:text-3xl font-black text-accent leading-none mb-1">{stat.value}</span>
            <span class="text-xs md:text-sm text-primary-foreground/70 font-semibold uppercase tracking-wide">{stat.label}</span>
          </div>
        ))}
      </div>
    </div>
  </div>

  <!-- Trust badges strip -->
  <div class="bg-muted/40 border-b border-border/40 py-3">
    <div class="container mx-auto px-4">
      <div class="flex flex-wrap items-center justify-center gap-6 text-sm font-semibold text-muted-foreground">
        <span class="flex items-center gap-1.5"><CheckCircle2 className="h-4 w-4 text-primary" /> Background-Checked Technicians</span>
        <span class="flex items-center gap-1.5"><CheckCircle2 className="h-4 w-4 text-primary" /> Satisfaction Guaranteed</span>
        <span class="flex items-center gap-1.5"><CheckCircle2 className="h-4 w-4 text-primary" /> NJ State Licensed & Bonded</span>
        <span class="flex items-center gap-1.5"><CheckCircle2 className="h-4 w-4 text-primary" /> Fast Local Dispatch</span>
      </div>
    </div>
  </div>

  <!-- Service Categories -->
  <section class="py-16 bg-foreground/5 border-y border-border/50">
    <div class="container mx-auto px-4">
      <div class="flex flex-col md:flex-row md:items-end justify-between mb-10 gap-4">
        <div class="max-w-2xl">
          <p class="text-accent font-bold uppercase tracking-widest text-xs mb-2">Our Services</p>
          <h2 class="text-3xl md:text-4xl font-serif font-bold text-foreground mb-4">Every Lock. Every Key.</h2>
          <p class="text-lg text-muted-foreground">
            From emergency lockouts to smart home upgrades — our NJ-licensed technicians cover every situation.
          </p>
        </div>
        <a href="/services" class="shrink-0 inline-flex items-center justify-center rounded-md border border-primary text-primary hover:bg-primary/10 min-h-9 px-4 py-2 font-medium">View All Services</a>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-5 mb-6">
        {categories.map((cat) => (
          <a href={`/services/${cat.slug}`}>
            <div class="group relative rounded-2xl overflow-hidden cursor-pointer h-64 hover:scale-[1.01] transition-transform duration-300">
              <img
                src={optimizeImageSrc(cat.heroImage, 1200)}
                alt={`${cat.name} locksmith service in New Jersey`}
                loading="lazy"
                decoding="async"
                class="absolute inset-0 w-full h-full object-cover opacity-50 group-hover:opacity-65 group-hover:scale-105 transition-all duration-500"
              />
              <div class="absolute inset-0 bg-gradient-to-t from-black/90 via-black/50 to-black/10" />
              <div class="absolute top-0 left-0 right-0 h-0.5 bg-accent opacity-0 group-hover:opacity-100 transition-opacity duration-300" />
              <div class="absolute inset-0 flex flex-col justify-end p-7">
                <div class="flex items-start justify-between">
                  <div>
                    <h3 class="text-2xl font-serif font-black text-white mb-1 group-hover:text-accent transition-colors duration-200">{cat.name}</h3>
                    <p class="text-white/60 text-sm mb-3 line-clamp-2 max-w-xs">{cat.subheadline}</p>
                    <div class="flex items-center gap-2">
                      <span class="text-white/40 text-xs font-semibold">{cat.subServices.length} services</span>
                      <span class="text-white/30">·</span>
                      <span class="flex items-center gap-1 text-accent text-xs font-bold group-hover:gap-2 transition-all duration-200">
                        Explore <ArrowRight className="h-3 w-3" />
                      </span>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Service Area Map -->
  <section class="py-14 bg-muted/30 border-b border-border/40">
    <div class="container mx-auto px-4">
      <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-4 mb-8">
        <div class="flex items-center gap-3">
          <MapPin className="h-7 w-7 text-primary shrink-0" />
          <div>
            <h2 class="text-2xl md:text-3xl font-serif font-bold text-foreground">Our Service Area</h2>
            <p class="text-muted-foreground">90+ cities across New Jersey, 40-mile radius from Camden</p>
          </div>
        </div>
        <a href="/locations" class="inline-flex items-center justify-center gap-1 rounded-md border border-primary text-primary hover:bg-primary/10 text-sm px-4 py-2 font-medium">
          View All Locations <ArrowRight className="h-4 w-4 ml-1" />
        </a>
      </div>
      <ServiceAreaMap client:load />
    </div>
  </section>

  <!-- Priority Pages -->
  <section class="py-12 bg-background border-b border-border/40">
    <div class="container mx-auto px-4">
      <div class="flex items-center justify-between mb-5">
        <h2 class="text-2xl font-serif font-bold text-foreground">Popular City + Service Pages</h2>
        <a href="/sitemap" class="text-sm font-semibold text-primary hover:underline">View HTML Sitemap</a>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-3">
        {PRIORITY_SERVICE_LOCATION_LINKS.map((item) => (
          <a href={item.href} class="rounded-lg border border-border px-4 py-3 text-sm font-medium text-foreground hover:border-primary hover:text-primary transition-colors">
            {item.label}
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Brands -->
  <section class="py-8 bg-background border-b border-border/40 overflow-hidden">
    <div class="container mx-auto px-4 mb-4">
      <p class="text-center text-xs font-bold uppercase tracking-widest text-muted-foreground">Certified to work with industry-leading brands</p>
    </div>
    <div class="relative flex">
      <div class="flex animate-[scroll_25s_linear_infinite] items-center gap-12 whitespace-nowrap">
        {BRANDS.map((brand) => (
          <span class="text-lg font-black text-foreground/25 uppercase tracking-wider shrink-0">{brand}</span>
        ))}
      </div>
    </div>
  </section>

  <!-- Quick Quote -->
  <section class="py-16" style="background: #0c1410;">
    <div class="container mx-auto px-4">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <div>
          <p class="text-accent font-bold uppercase tracking-widest text-xs mb-3">Quick Quote</p>
          <h2 class="text-3xl md:text-4xl font-serif font-bold text-white mb-6">Get a Quote in<br />30 Seconds</h2>
          <p class="text-white/60 text-lg mb-8">No obligation. Our professional NJ locksmith team responds promptly to all requests.</p>
          <div class="flex flex-col gap-4 text-sm">
            {["Background-Checked Field Pros", "Satisfaction Guaranteed", "NJ Licensed, Bonded & Insured", "Fast Local Dispatch"].map((item) => (
              <div class="flex items-center gap-3">
                <CheckCircle2 className="h-5 w-5 text-accent shrink-0" />
                <span class="text-white/80 font-medium">{item}</span>
              </div>
            ))}
          </div>
        </div>
        <div class="rounded-2xl border border-white/10 p-8" style="background: rgba(0,0,0,0.45); backdrop-filter: blur(12px);">
          <BookingForm client:load darkBg />
        </div>
      </div>
    </div>
  </section>

  <!-- About / Story -->
  <section class="py-20 bg-foreground text-background">
    <div class="container mx-auto px-4">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
        <div>
          <span class="inline-block bg-accent text-accent-foreground text-xs font-black uppercase tracking-widest px-3 py-1 rounded-full mb-6">15+ Years</span>
          <h2 class="text-4xl md:text-5xl font-serif font-black leading-none mb-8">New Jersey's<br />Security Authority</h2>
          <p class="text-background/70 text-lg mb-6 leading-relaxed">
            For over 15 years, Garden State Locksmith has been the trusted security authority for homeowners, businesses, and drivers across New Jersey. We don't just open locks — we engineer peace of mind through technical precision and local expertise.
          </p>
          <p class="text-background/70 text-lg mb-8 leading-relaxed">
            Our field technicians are NJ-certified master locksmiths, equipped with industrial-grade tools to resolve any security challenge — from a 3 AM lockout to a full commercial access control installation.
          </p>
          <div class="grid grid-cols-3 gap-6 mb-8">
            {[["15+", "Years in NJ"], ["5★", "Google Rating"], ["90+", "Cities Covered"]].map(([val, lab]) => (
              <div class="text-center">
                <div class="text-3xl font-black text-accent mb-1">{val}</div>
                <div class="text-xs text-background/60 font-semibold uppercase tracking-wide">{lab}</div>
              </div>
            ))}
          </div>
          <div class="flex gap-4">
            <a href="tel:8565880580" class="flex items-center gap-2 bg-accent text-accent-foreground font-bold px-6 py-3 rounded-full hover:bg-accent/90 transition-colors">
              <Phone className="h-4 w-4" /> Dispatch Now
            </a>
            <a href="/about" class="flex items-center gap-2 border border-background/30 text-background font-semibold px-6 py-3 rounded-full hover:bg-background/10 transition-colors">
              Our Story →
            </a>
          </div>
        </div>
        <div class="grid grid-cols-2 gap-4">
          {[
            { num: "01", title: "NJ Licensed & Insured", desc: "Every technician fully certified, bonded, and background-checked for your complete peace of mind." },
            { num: "02", title: "Rapid Response", desc: "When you're locked out, every minute counts. We dispatch the nearest tech immediately." },
            { num: "03", title: "Satisfaction Guaranteed", desc: "We stand behind every job we complete. If you're not fully satisfied, we make it right — no questions asked." },
            { num: "04", title: "5-Star Service", desc: "Customers across New Jersey trust us for reliable, professional, first-time-right results." },
          ].map(({ num, title, desc }) => (
            <div class="bg-white/5 border border-white/10 rounded-2xl p-5 hover:bg-white/10 transition-colors">
              <div class="text-accent font-black text-sm mb-3">{num}</div>
              <h3 class="font-bold text-sm text-background mb-2">{title}</h3>
              <p class="text-background/50 text-xs leading-relaxed">{desc}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <EmergencyCTA />

  <!-- Service Areas -->
  <section class="py-16 bg-background">
    <div class="container mx-auto px-4">
      <div class="flex flex-col md:flex-row md:items-end justify-between mb-10 gap-4">
        <div class="max-w-2xl">
          <p class="text-accent font-bold uppercase tracking-widest text-xs mb-2">Service Coverage</p>
          <h2 class="text-3xl md:text-4xl font-serif font-bold text-foreground mb-4">Serving All of New Jersey</h2>
          <p class="text-lg text-muted-foreground">
            Rapid-response locksmith service throughout Camden, Burlington, Gloucester, Mercer, Ocean, Monmouth, and every county in between.
          </p>
        </div>
        <a href="/locations" class="shrink-0 inline-flex items-center justify-center rounded-md border border-primary text-primary hover:bg-primary/10 min-h-9 px-4 py-2 font-medium">View All Areas</a>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-4">
        {topLocations.map((location) => (
          <LocationCard location={location} />
        ))}
      </div>
    </div>
  </section>

  <TestimonialSection />

  <!-- FAQ -->
  <section class="py-16 bg-muted/30">
    <div class="container mx-auto px-4">
      <div class="text-center mb-10">
        <p class="text-accent font-bold uppercase tracking-widest text-xs mb-2">FAQs</p>
        <h2 class="text-3xl md:text-4xl font-serif font-bold text-foreground mb-4">Common Questions</h2>
        <p class="text-lg text-muted-foreground max-w-2xl mx-auto">
          Answers to the questions we hear most from New Jersey homeowners, businesses, and drivers.
        </p>
      </div>
      <FAQAccordion faqs={faqs} />
    </div>
  </section>
</BaseLayout>
