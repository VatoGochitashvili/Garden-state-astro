---
import BaseLayout from "@/layouts/BaseLayout.astro";
import EmergencyCTA from "@/components/shared/EmergencyCTA.astro";
import { blogPosts } from "@/data/blogPosts";
import { optimizeImageSrc } from "@/lib/image";
import { Calendar, User, ArrowLeft, Tag } from "lucide-react";

export function getStaticPaths() {
  return blogPosts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const related = blogPosts.filter((p) => p.slug !== post.slug).slice(0, 3);

const html = post.content
  .replace(/\n/g, "<br/>")
  .replace(/## (.*?)(<br\/>|$)/g, "<h2>$1</h2>")
  .replace(/### (.*?)(<br\/>|$)/g, "<h3>$1</h3>")
  .replace(/\*\*(.*?)\*\*/g, "<strong>$1</strong>");

const schema = {
  "@context": "https://schema.org",
  "@type": "Article",
  headline: post.title,
  datePublished: post.date,
  author: { "@type": "Organization", name: post.author },
  publisher: {
    "@type": "Organization",
    name: "Garden State Locksmith",
    logo: { "@type": "ImageObject", url: "/logo.png" },
  },
  description: post.metaDescription,
  image: post.image,
};
---

<BaseLayout
  title={post.metaTitle}
  description={post.metaDescription}
  canonical={`/blog/${post.slug}`}
  ogType="article"
  schema={schema}
  breadcrumbs={[
    { name: "Home", path: "/" },
    { name: "Blog", path: "/blog/" },
    { name: post.title, path: `/blog/${post.slug}/` },
  ]}
>
  <div class="relative bg-primary text-primary-foreground py-16 overflow-hidden">
    <div class="absolute inset-0 pointer-events-none">
      <img
        src={optimizeImageSrc(post.image, 1600)}
        alt=""
        aria-hidden="true"
        fetchpriority="high"
        class="w-full h-full object-cover opacity-20 mix-blend-luminosity"
      />
    </div>
    <div class="container mx-auto px-4 relative z-10 max-w-3xl">
      <a href="/blog/" class="inline-flex items-center gap-1 mb-6 text-primary-foreground/70 hover:text-primary-foreground -ml-2">
        <ArrowLeft className="h-4 w-4 mr-1" /> Back to Blog
      </a>
      <div class="flex items-center gap-2 mb-4">
        <span class="bg-accent/20 text-accent border border-accent/30 text-xs font-semibold px-3 py-1 rounded-full flex items-center gap-1">
          <Tag className="h-3 w-3" />{post.category}
        </span>
      </div>
      <h1 class="text-3xl md:text-4xl lg:text-5xl font-serif font-bold tracking-tight mb-4">{post.title}</h1>
      <div class="flex items-center gap-6 text-primary-foreground/70 text-sm">
        <span class="flex items-center gap-1"><Calendar className="h-4 w-4" />{new Date(post.date).toLocaleDateString("en-US", { year: "numeric", month: "long", day: "numeric" })}</span>
        <span class="flex items-center gap-1"><User className="h-4 w-4" />{post.author}</span>
      </div>
    </div>
  </div>

  <section class="py-16 bg-background">
    <div class="container mx-auto px-4">
      <div class="max-w-3xl mx-auto">
        <div
          class="prose prose-lg max-w-none prose-headings:font-serif prose-headings:text-foreground prose-p:text-muted-foreground prose-a:text-primary prose-strong:text-foreground prose-li:text-muted-foreground prose-td:text-muted-foreground prose-th:text-foreground"
          set:html={html}
        />

        <div class="mt-12 p-8 bg-primary rounded-xl text-primary-foreground text-center">
          <h3 class="font-serif font-bold text-2xl mb-3">Need a Locksmith in New Jersey?</h3>
          <p class="text-primary-foreground/80 mb-6">Garden State Locksmith provides fast, professional service throughout New Jersey — 7 AM – 10 PM, 6 days a week.</p>
          <a href="tel:8565880580" class="inline-flex items-center justify-center rounded-md bg-accent text-accent-foreground hover:bg-accent/90 font-bold min-h-10 px-8 text-lg">Call (856) 588-0580</a>
        </div>

        {related.length > 0 && (
          <div class="mt-16">
            <h2 class="text-2xl font-serif font-bold mb-6">Related Articles</h2>
            <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
              {related.map((r) => (
                <a href={`/blog/${r.slug}/`} class="group block border border-border rounded-xl overflow-hidden hover:shadow-md transition-shadow">
                  <div class="h-32 overflow-hidden">
                    <img
                      src={optimizeImageSrc(r.image, 800)}
                      alt={`${r.title} article cover`}
                      loading="lazy"
                      decoding="async"
                      class="w-full h-full object-cover group-hover:scale-105 transition-transform"
                    />
                  </div>
                  <div class="p-4">
                    <span class="text-xs font-semibold text-accent">{r.category}</span>
                    <h3 class="font-serif font-bold text-sm mt-1 text-foreground group-hover:text-primary transition-colors line-clamp-2">{r.title}</h3>
                  </div>
                </a>
              ))}
            </div>
          </div>
        )}
      </div>
    </div>
  </section>

  <EmergencyCTA />
</BaseLayout>
