---
import BaseLayout from "@/layouts/BaseLayout.astro";
---

<BaseLayout title="Page Not Found | Garden State Locksmith" description="The page you're looking for could not be found." noIndex={true}>
  <div class="min-h-[60vh] w-full flex items-center justify-center bg-muted/30 py-24">
    <div class="w-full max-w-md mx-4 rounded-xl border bg-card p-8 text-center">
      <h1 class="text-3xl font-serif font-bold text-foreground mb-3">404 — Page Not Found</h1>
      <p class="text-muted-foreground mb-6">
        The page you're looking for doesn't exist or may have been moved.
      </p>
      <div class="flex flex-wrap justify-center gap-3">
        <a href="/" class="inline-flex items-center justify-center rounded-md bg-primary text-primary-foreground font-bold min-h-10 px-6">Back to Home</a>
        <a href="tel:8565880580" class="inline-flex items-center justify-center rounded-md border border-primary text-primary font-bold min-h-10 px-6">Call (856) 588-0580</a>
      </div>
    </div>
  </div>
</BaseLayout>
