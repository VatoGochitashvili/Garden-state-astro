---
import { Phone, ShieldCheck } from "lucide-react";
import { optimizeImageSrc } from "@/lib/image";

const DEFAULT_HERO_IMAGE = "/van-bg.jpg";

interface Props {
  h1: string;
  subtitle: string;
  image?: string;
  emergency?: boolean;
  companyName?: string;
}

const { h1, subtitle, image, emergency = false, companyName } = Astro.props;
const bgImage = image ?? DEFAULT_HERO_IMAGE;
---

<div class="relative overflow-hidden text-white py-16 lg:py-24" style="background: #0c1410;">
  <div class="absolute inset-0 pointer-events-none">
    <img
      src={optimizeImageSrc(bgImage, 1600)}
      alt=""
      aria-hidden="true"
      fetchpriority="high"
      class="w-full h-full object-cover opacity-40"
    />
    <div class="absolute inset-0 bg-gradient-to-r from-black/80 via-black/55 to-black/75" />
    <div class="absolute inset-0 bg-gradient-to-t from-black/60 via-transparent to-black/30" />
  </div>

  <div class="absolute bottom-0 left-0 w-96 h-48 bg-primary/20 blur-3xl pointer-events-none" />

  <div class="container mx-auto px-4 relative z-10">
    <div class="max-w-3xl">
      {emergency && (
        <div class="inline-flex items-center rounded-full border border-accent/50 bg-accent/15 px-3 py-1 text-sm font-semibold text-accent mb-6">
          <span class="flex h-2 w-2 rounded-full bg-accent mr-2 animate-pulse"></span>
          Fast Response · Licensed NJ Technicians
        </div>
      )}

      {companyName && (
        <p class="text-accent font-bold uppercase tracking-[0.2em] text-sm md:text-base mb-3">{companyName}</p>
      )}

      <h1 class="text-4xl md:text-5xl lg:text-6xl font-serif font-bold tracking-tight mb-6 text-white drop-shadow-lg">
        {h1}
      </h1>

      <p class="text-lg md:text-xl text-white/80 mb-8 max-w-2xl font-medium leading-relaxed">
        {subtitle}
      </p>

      <div class="flex flex-col sm:flex-row gap-4 mb-8">
        <a
          href="tel:8565880580"
          class="inline-flex items-center justify-center gap-2 bg-accent text-accent-foreground hover:bg-accent/90 font-bold text-lg px-8 py-6 h-auto rounded-md transition-colors"
        >
          <Phone className="h-6 w-6" />
          (856) 588-0580
        </a>
        <a
          href="/contact"
          class="inline-flex items-center justify-center gap-2 border border-white/30 text-white hover:bg-white/10 font-bold text-lg px-8 py-6 h-auto rounded-md transition-colors"
        >
          Request a Quote
        </a>
      </div>

      <div class="flex items-center gap-6 text-sm font-semibold text-white/70">
        <div class="flex items-center gap-2">
          <ShieldCheck className="h-5 w-5 text-accent" />
          <span>Licensed & Insured</span>
        </div>
        <div class="hidden sm:flex items-center gap-2">
          <ShieldCheck className="h-5 w-5 text-accent" />
          <span>Fast Response Time</span>
        </div>
      </div>
    </div>
  </div>
</div>
