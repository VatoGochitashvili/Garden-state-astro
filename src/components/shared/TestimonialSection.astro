---
import { Star } from "lucide-react";

const testimonials = [
  { name: "Sarah M.", location: "Cherry Hill, NJ", text: "Locked myself out of my house at 11 PM on a Tuesday. They arrived in 20 minutes and got me in without breaking the lock. Lifesavers!", rating: 5 },
  { name: "James T.", location: "Camden, NJ", text: "Upgraded all the locks on our new commercial building. Professional, fast, and the pricing was exactly what they quoted over the phone.", rating: 5 },
  { name: "Emily R.", location: "Voorhees, NJ", text: "Lost my car keys at the mall. The dealer wanted to tow it and charge a fortune. Garden State made a new fob on the spot for much less.", rating: 5 },
  { name: "Michael B.", location: "Moorestown, NJ", text: "Installed a new smart deadbolt for us. The technician walked us through how to use the app and was extremely polite.", rating: 5 },
  { name: "David K.", location: "Trenton, NJ", text: "Honest locksmiths are hard to find. These guys are the real deal. Fixed a jammed lock instead of trying to sell me a new one.", rating: 5 },
  { name: "Jessica W.", location: "Woodbury, NJ", text: "Fastest response time I've ever experienced. Highly recommend for anyone in New Jersey who needs a reliable locksmith.", rating: 5 },
];
---

<section class="py-16 relative overflow-hidden" style="background-color: hsl(var(--primary));">
  <div class="absolute inset-0 pointer-events-none">
    <img
      src="https://images.unsplash.com/photo-1449824913935-59a10b8d2000?w=1600&q=80"
      alt=""
      class="w-full h-full object-cover opacity-15 mix-blend-luminosity"
      loading="lazy"
    />
  </div>

  <div class="container mx-auto px-4 relative z-10">
    <div class="text-center mb-12">
      <h2 class="text-3xl md:text-4xl font-serif font-bold text-primary-foreground mb-4">Trusted Across New Jersey</h2>
      <p class="text-lg text-primary-foreground/70 max-w-2xl mx-auto">
        Don't just take our word for it. See what your neighbors have to say about our locksmith services.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {testimonials.map((t) => (
        <div class="rounded-xl border bg-background/10 border-primary-foreground/20 backdrop-blur-sm p-6">
          <div class="flex text-accent mb-2">
            {[...Array(t.rating)].map(() => (
              <Star className="h-4 w-4 fill-current" />
            ))}
          </div>
          <p class="text-primary-foreground/80 italic mb-4">"{t.text}"</p>
          <div class="font-semibold text-primary-foreground">{t.name}</div>
          <div class="text-sm text-accent">{t.location}</div>
        </div>
      ))}
    </div>
  </div>
</section>
