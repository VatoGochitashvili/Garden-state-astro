---
import { Phone } from "lucide-react";
import { MobileMenu } from "@/components/shared/MobileMenu";
import logoPath from "@/assets/logo-optimized.png";

const leftLinks = [
  { href: "/", label: "Home" },
  { href: "/services", label: "Services" },
  { href: "/locations", label: "Locations" },
  { href: "/blog", label: "Blog" },
];

const rightLinks = [
  { href: "/faq", label: "FAQ" },
  { href: "/about", label: "About" },
  { href: "/contact", label: "Contact" },
];
---

<header class="fixed top-0 left-0 right-0 z-[1001]">
  <!-- Desktop — floating pill -->
  <div class="hidden md:flex items-center justify-between max-w-6xl mx-auto px-8 h-14 relative mt-4 rounded-2xl bg-white border border-white shadow-xl shadow-black/10">
    <nav class="flex items-center gap-0.5">
      {leftLinks.map((link) => (
        <a
          href={link.href}
          class="relative px-3 py-2 text-[12.5px] font-bold uppercase tracking-wide text-foreground/70 hover:text-primary rounded-xl hover:bg-primary/8 transition-all duration-200 group whitespace-nowrap"
        >
          {link.label}
          <span class="absolute bottom-1 left-1/2 -translate-x-1/2 w-0 h-0.5 bg-primary rounded-full transition-all duration-200 group-hover:w-4" />
        </a>
      ))}
    </nav>

    <a href="/" class="group absolute left-1/2" style="top: 50%; transform: translate(-50%, -50%);">
      <img
        src={logoPath.src}
        alt="Garden State Locksmith"
        width="72"
        height="72"
        fetchpriority="high"
        class="h-[4.5rem] w-[4.5rem] object-contain transition-transform duration-300 group-hover:scale-110"
      />
    </a>

    <nav class="flex items-center gap-0.5">
      {rightLinks.map((link) => (
        <a
          href={link.href}
          class="relative px-3 py-2 text-[12.5px] font-bold uppercase tracking-wide text-foreground/70 hover:text-primary rounded-xl hover:bg-primary/8 transition-all duration-200 group whitespace-nowrap"
        >
          {link.label}
          <span class="absolute bottom-1 left-1/2 -translate-x-1/2 w-0 h-0.5 bg-primary rounded-full transition-all duration-200 group-hover:w-4" />
        </a>
      ))}

      <a
        href="tel:8565880580"
        class="ml-2 flex items-center gap-1.5 bg-primary text-primary-foreground text-xs font-bold px-4 py-2 rounded-full shadow-lg hover:bg-primary/90 hover:shadow-xl transition-all duration-200 whitespace-nowrap"
      >
        <Phone className="h-3.5 w-3.5" />
        (856) 588-0580
      </a>
    </nav>
  </div>

  <!-- Mobile -->
  <div class="flex md:hidden items-center justify-between px-4 h-16 bg-white/95 backdrop-blur-sm shadow-sm">
    <a href="/" class="group flex items-center">
      <img
        src={logoPath.src}
        alt="Garden State Locksmith"
        width="44"
        height="44"
        fetchpriority="high"
        class="h-11 w-11 object-contain transition-transform duration-300 group-hover:scale-110"
      />
    </a>

    <div class="flex items-center gap-2">
      <a
        href="tel:8565880580"
        class="flex items-center gap-1 bg-primary text-primary-foreground text-xs font-bold px-3 py-2 rounded-full shadow-lg"
      >
        <Phone className="h-3.5 w-3.5" />
        Call
      </a>
      <MobileMenu client:load />
    </div>
  </div>
</header>
