---
import "../styles/global.css";
import Header from "@/components/layout/Header.astro";
import Footer from "@/components/layout/Footer.astro";
import CallToActionBar from "@/components/layout/CallToActionBar.astro";
import NeedLocksmithCTA from "@/components/shared/NeedLocksmithCTA.astro";
import { DOMAIN, localBusinessSchema } from "@/lib/seo";

interface Props {
  title: string;
  description: string;
  canonical?: string;
  ogType?: string;
  imageUrl?: string;
  schema?: object | object[];
  noIndex?: boolean;
  hideCtas?: boolean;
}

const {
  title,
  description,
  canonical,
  ogType = "website",
  imageUrl,
  schema,
  noIndex = false,
  hideCtas = false,
} = Astro.props;

const canonicalUrl = canonical ? `${DOMAIN}${canonical}` : `${DOMAIN}${Astro.url.pathname}`;
const resolvedImage = imageUrl ?? `${DOMAIN}/opengraph.jpg`;
const ogImage = resolvedImage.startsWith("http") ? resolvedImage : `${DOMAIN}${resolvedImage}`;

const schemas = [localBusinessSchema(), ...(schema ? (Array.isArray(schema) ? schema : [schema]) : [])];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>{title}</title>
    <meta name="description" content={description} />
    <meta
      name="robots"
      content={noIndex ? "noindex, nofollow" : "index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1"}
    />
    <meta name="theme-color" content="#1B4D2E" />
    <link rel="canonical" href={canonicalUrl} />

    <meta property="og:type" content={ogType} />
    <meta property="og:site_name" content="Garden State Locksmith" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:locale" content="en_US" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <meta name="geo.region" content="US-NJ" />
    <meta name="geo.placename" content="New Jersey" />

    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="icon" type="image/png" sizes="96x96" href="/icon-96.png" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16.png" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />

    {schemas.map((s) => <script type="application/ld+json" set:html={JSON.stringify(s)} />)}
  </head>
  <body class="min-h-screen flex flex-col font-sans antialiased bg-background text-foreground">
    <Header />
    <main class="flex-1">
      <slot />
    </main>
    {!hideCtas && <NeedLocksmithCTA />}
    <Footer />
    {!hideCtas && <CallToActionBar />}
  </body>
</html>
